{
  "name": "dopamindetox-extension",
  "version": "0.1.0",
  "description": "Dopamin Detox — cross-browser website blocker (Chrome, Edge, Firefox). Local-only, no backend.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "icons": "node scripts/gen-icons.mjs",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "wxt": "^0.20.26"
  }
}
